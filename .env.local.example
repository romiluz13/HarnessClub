# AgentConfig local environment
# Copy this file to .env.local and fill in the values you actually use.

# MongoDB
# Atlas cloud: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Atlas local preview: mongodb://localhost:27018/?directConnection=true
# Plain MongoDB: mongodb://localhost:27017/agentconfig
MONGODB_URI=mongodb://localhost:27017/agentconfig
MONGODB_DB_NAME=agentconfig

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (required for UI sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional semantic search
VOYAGE_API_KEY=

# Optional copilot provider
# COPILOT_PROVIDER=grove
# COPILOT_MODEL=gpt-5.4
# COPILOT_BASE_URL=https://your-openai-compatible-endpoint/v1/chat/completions
# COPILOT_API_KEY=
# COPILOT_API_KEY_HEADER=api-key
