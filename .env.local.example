# SkillsHub Environment Variables
# Copy this file to .env.local and fill in the values.

# MongoDB Atlas M0 Connection String
# Get from: cloud.mongodb.com → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=skillshub

# Voyage AI API Key (for semantic search embeddings)
# Get from: dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth.js Configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (for authentication)
# Create at: github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
